<world>
    <window width="1024" height="768" />
    <camera>
        <position x="150" y="80" z="150" />
        <lookAt x="0" y="0" z="0" />
        <up x="0" y="1" z="0" />
        <projection fov="60" near="1" far="1000" />
    </camera>
 
    <!-- ===================== SOL ===================== -->
    <group>
        <transform>
            <scale x="15" y="15" z="15" />
        </transform>
        <models>
            <model file="sphere.3d" />
        </models>
    </group>
 
    <!-- ===================== MERCURIO ===================== -->
    <!-- Orbita mais excentrica do sistema (e=0.21) — elipse achatada com 8 pontos -->
    <group>
        <transform>
            <translate time="10" align="False">
                <point x="24"  y="0" z="0"   />
                <point x="19"  y="0" z="13"  />
                <point x="0"   y="0" z="18"  />
                <point x="-19" y="0" z="13"  />
                <point x="-18" y="0" z="0"   />
                <point x="-19" y="0" z="-13" />
                <point x="0"   y="0" z="-18" />
                <point x="19"  y="0" z="-13" />
            </translate>
        </transform>
        <group>
            <transform>
                <rotate time="5" x="0" y="1" z="0" />
                <scale x="0.4" y="0.4" z="0.4" />
            </transform>
            <models>
                <model file="sphere.3d" />
            </models>
        </group>
    </group>
 
    <!-- ===================== VENUS ===================== -->
    <!-- Orbita quase circular (e=0.007), ligeiramente achatada -->
    <group>
        <transform>
            <translate time="18" align="False">
                <point x="32"  y="0" z="0"   />
                <point x="23"  y="0" z="23"  />
                <point x="0"   y="0" z="31"  />
                <point x="-23" y="0" z="23"  />
                <point x="-30" y="0" z="0"   />
                <point x="-23" y="0" z="-23" />
                <point x="0"   y="0" z="-31" />
                <point x="23"  y="0" z="-23" />
            </translate>
        </transform>
        <group>
            <transform>
                <!-- Venus roda ao contrario (retrógrada) e muito devagar -->
                <rotate time="60" x="0" y="-1" z="0" />
                <scale x="0.9" y="0.9" z="0.9" />
            </transform>
            <models>
                <model file="sphere.3d" />
            </models>
        </group>
    </group>
 
    <!-- ===================== TERRA ===================== -->
    <group>
        <transform>
            <translate time="30" align="False">
                <point x="42"  y="0" z="0"   />
                <point x="30"  y="0" z="30"  />
                <point x="0"   y="0" z="41"  />
                <point x="-30" y="0" z="30"  />
                <point x="-40" y="0" z="0"   />
                <point x="-30" y="0" z="-30" />
                <point x="0"   y="0" z="-41" />
                <point x="30"  y="0" z="-30" />
            </translate>
        </transform>
        <!-- Terra com inclinacao axial -->
        <group>
            <transform>
                <rotate time="10" x="0" y="1" z="0" />
                <scale x="1" y="1" z="1" />
            </transform>
            <models>
                <model file="sphere.3d" />
            </models>
        </group>
        <!-- Lua — orbita em torno da Terra -->
        <group>
            <transform>
                <translate time="5" align="False">
                    <point x="4"  y="0.5"  z="0"  />
                    <point x="0"  y="0"    z="4"  />
                    <point x="-4" y="-0.5" z="0"  />
                    <point x="0"  y="0"    z="-4" />
                </translate>
                <scale x="0.3" y="0.3" z="0.3" />
            </transform>
            <models>
                <model file="sphere.3d" />
            </models>
        </group>
    </group>
 
    <!-- ===================== MARTE ===================== -->
    <!-- e=0.093 — elipse visivel, mais rapido no perigeo -->
    <group>
        <transform>
            <translate time="40" align="False">
                <point x="60"  y="0" z="0"   />
                <point x="44"  y="0" z="40"  />
                <point x="0"   y="0" z="55"  />
                <point x="-44" y="0" z="40"  />
                <point x="-52" y="0" z="0"   />
                <point x="-44" y="0" z="-40" />
                <point x="0"   y="0" z="-55" />
                <point x="44"  y="0" z="-40" />
            </translate>
        </transform>
        <group>
            <transform>
                <rotate time="12" x="0" y="1" z="0" />
                <scale x="0.8" y="0.8" z="0.8" />
            </transform>
            <models>
                <model file="sphere.3d" />
            </models>
        </group>
    </group>
 
    <!-- ===================== COMETA 1 ===================== -->
    <!--
        Orbita muito excentrica e inclinada, tipo cometa de Halley.
        TRUQUE DA VELOCIDADE VARIAVEL:
          - Pontos juntos na zona interior (perihelio) = o cometa passa RAPIDO
          - Pontos afastados na zona exterior (afelio)  = o cometa ABRANDA
        Isto simula a lei das areas de Kepler sem fisica real.
    -->
    <group>
        <transform>
            <translate time="35" align="true">
                <!-- periélio próximo do Sol -->
                <point x="20"  y="-5"  z="10"  />
                <point x="5"   y="-15" z="35"  />
                <point x="-30" y="-20" z="50"  />
                <point x="-55" y="-10" z="35"  />
                <!-- afélio afastado -->
                <point x="-85" y="5"   z="0"   />
                <point x="-70" y="15"  z="-40" />
                <point x="-30" y="10"  z="-60" />
                <point x="10"  y="0"   z="-35" />
            </translate>
            <!-- Tumbling 3D realista: o cometa gira em torno de eixo nao-alinhado -->
            <rotate time="6" x="0.4" y="0.8" z="0.2" />
            <scale x="2" y="2" z="2" />
        </transform>
        <models>
            <model file="comet.3d" />
        </models>
    </group>
    
<!-- ==================== COMETA 2 ======================= -->
    <group>
        <transform>
            <translate time="22" align="true">
                <point x="400.00" y="10" z="0.00" />
                <point x="369.55" y="10" z="15.31" />
                <point x="282.84" y="10" z="28.28" />
                <point x="153.07" y="10" z="36.96" />
                
                <point x="0.00" y="10" z="40.00" />
                <point x="-153.07" y="10" z="36.96" />
                <point x="-282.84" y="10" z="28.28" />
                <point x="-369.55" y="10" z="15.31" />
                
                <point x="-400.00" y="10" z="0.00" />
                <point x="-369.55" y="10" z="-15.31" />
                <point x="-282.84" y="10" z="-28.28" />
                <point x="-153.07" y="10" z="-36.96" />
                
                <point x="0.00" y="10" z="-40.00" />
                <point x="153.07" y="10" z="-36.96" />
                <point x="282.84" y="10" z="-28.28" />
                <point x="369.55" y="10" z="-15.31" />
            </translate>
            <!-- Tumbling 3D realista: o cometa gira em torno de eixo nao-alinhado -->
            <rotate time="6" x="0.4" y="0.8" z="0.2" />
            <scale x="2" y="2" z="2" />
        </transform>
        <models>
            <model file="comet.3d" />
        </models>
    </group>

    <!-- ===================== JUPITER ===================== -->
    <group>
        <transform>
            <translate time="60" align="False">
                <point x="78"  y="0" z="0"   />
                <point x="55"  y="0" z="55"  />
                <point x="0"   y="0" z="76"  />
                <point x="-55" y="0" z="55"  />
                <point x="-75" y="0" z="0"   />
                <point x="-55" y="0" z="-55" />
                <point x="0"   y="0" z="-76" />
                <point x="55"  y="0" z="-55" />
            </translate>
        </transform>
        <group>
            <transform>
                <!-- Jupiter tem rotacao muito rapida (~10h) -->
                <rotate time="8" x="0" y="1" z="0" />
                <scale x="5.5" y="5.5" z="5.5" />
            </transform>
            <models>
                <model file="sphere.3d" />
            </models>
        </group>
    </group>
 
    <!-- ===================== SATURNO ===================== -->
    <!--
        o torus dos aneis esta agora dentro do grupo
        de Saturno (filho), para que acompanhe o planeta na sua orbita.
        Antes estava como irmao e ficava sempre na origem (0,0,0).
    -->
    <group>
        <transform>
            <translate time="80" align="False">
                <point x="105"  y="0" z="0"    />
                <point x="74"   y="0" z="74"   />
                <point x="0"    y="0" z="102"  />
                <point x="-74"  y="0" z="74"   />
                <point x="-100" y="0" z="0"    />
                <point x="-74"  y="0" z="-74"  />
                <point x="0"    y="0" z="-102" />
                <point x="74"   y="0" z="-74"  />
            </translate>
        </transform>
        <!-- Esfera de Saturno -->
        <group>
            <transform>
                <rotate time="18" x="0" y="1" z="0" />
                <scale x="4" y="4" z="4" />
            </transform>
            <models>
                <model file="sphere.3d" />
            </models>
        </group>
        <!-- Aneis de Saturno — filho do grupo de Saturno, acompanha o planeta -->
        <group>
            <transform>
                <scale x="5.5" y="0.15" z="5.5" />
            </transform>
            <models>
                <model file="torus.3d" />
            </models>
        </group>
    </group>
 
    <!-- ===================== URANO ===================== -->
    <!--
        Urano tem inclinacao axial de ~98 graus — roda "de lado".
        Simulado com eixo de rotacao quase horizontal.
    -->
    <group>
        <transform>
            <translate time="100" align="False">
                <point x="130"  y="0" z="0"    />
                <point x="92"   y="0" z="92"   />
                <point x="0"    y="0" z="128"  />
                <point x="-92"  y="0" z="92"   />
                <point x="-125" y="0" z="0"    />
                <point x="-92"  y="0" z="-92"  />
                <point x="0"    y="0" z="-128" />
                <point x="92"   y="0" z="-92"  />
            </translate>
        </transform>
        <group>
            <transform>
                <!-- Eixo quase horizontal simula inclinacao de 98 graus de Urano -->
                <rotate time="22" x="0.99" y="0.1" z="0" />
                <scale x="2.5" y="2.5" z="2.5" />
            </transform>
            <models>
                <model file="sphere.3d" />
            </models>
        </group>
    </group>
 
    <!-- ===================== NEPTUNO ===================== -->
    <group>
        <transform>
            <translate time="120" align="False">
                <point x="160"  y="0" z="0"    />
                <point x="113"  y="0" z="113"  />
                <point x="0"    y="0" z="157"  />
                <point x="-113" y="0" z="113"  />
                <point x="-155" y="0" z="0"    />
                <point x="-113" y="0" z="-113" />
                <point x="0"    y="0" z="-157" />
                <point x="113"  y="0" z="-113" />
            </translate>
        </transform>
        <group>
            <transform>
                <rotate time="25" x="0" y="1" z="0" />
                <scale x="2.2" y="2.2" z="2.2" />
            </transform>
            <models>
                <model file="sphere.3d" />
            </models>
        </group>
    </group>
 
</world>